# ─────────────────────────────────────────────────────────────
# LEGACY MOVING — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git
# ─────────────────────────────────────────────────────────────

# Chave secreta para geração dos tokens JWT (obrigatória em produção)
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE-POR-UMA-CHAVE-FORTE-EM-PRODUCAO

# URL do banco de dados
# SQLite local (padrão — criado automaticamente na pasta src/):
DATABASE_URL=
# PostgreSQL Railway (fornecida automaticamente pelo Railway):
# DATABASE_URL=postgresql://user:pass@host:5432/db

# Porta do servidor (Railway injeta automaticamente em produção)
PORT=5000

# Ambiente Flask
FLASK_ENV=production
FLASK_DEBUG=False

# ─────────────────────────────────────────────────────────────
# GOOGLE CALENDAR — Sincronização de Etapas Operacionais
# ─────────────────────────────────────────────────────────────
# Passo a passo de configuração:
#   1. Acesse console.cloud.google.com → Criar projeto → Ativar "Google Calendar API"
#   2. APIs e serviços → Credenciais → Criar credenciais → Conta de serviço
#   3. Clique na conta criada → Chaves → Adicionar chave → JSON
#   4. Abra o JSON baixado, copie TODO o conteúdo (incluindo as chaves {})
#   5. Cole aqui SEM quebras de linha:
#
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
#   6. No Google Calendar: Configurações → Calendários → Compartilhar com usuário
#      Cole o email da conta de serviço (campo "client_email" do JSON)
#      Permissão: "Fazer alterações nos eventos"
#   7. Copie o ID do calendário (em Configurações → ID do calendário)

GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# ─────────────────────────────────────────────────────────────
# IA MIRANTE — Claude / Anthropic
# ─────────────────────────────────────────────────────────────
# Acesse console.anthropic.com → API Keys → Criar chave
# NUNCA exponha esta chave no código ou logs

ANTHROPIC_API_KEY=
