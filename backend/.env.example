# ─────────────────────────────────────────────────────────────
# LEGACY MOVING — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git
# ─────────────────────────────────────────────────────────────

# Chave secreta para geração dos tokens JWT (obrigatória em produção)
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE-POR-UMA-CHAVE-FORTE-EM-PRODUCAO

# URL do banco de dados
# SQLite local (padrão — criado automaticamente na pasta src/):
DATABASE_URL=
# PostgreSQL Railway (fornecida automaticamente pelo Railway):
# DATABASE_URL=postgresql://user:pass@host:5432/db

# Porta do servidor (Railway injeta automaticamente em produção)
PORT=5000

# Ambiente Flask
FLASK_ENV=production
FLASK_DEBUG=False
